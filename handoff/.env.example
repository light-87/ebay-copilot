# Copy to .env in the repo root and fill in the real values (sent privately).
# The real .env is git-ignored — never commit it.

# eBay app credentials (from the Production "Listing creator" keyset)
EBAY_CLIENT_ID=your-app-id
EBAY_CLIENT_SECRET=your-cert-id

# RuName the OAuth token was minted with (must match, or refresh fails)
EBAY_REDIRECT_URI=your-runame

EBAY_ENVIRONMENT=production
EBAY_MARKETPLACE_ID=EBAY_GB

# IMPORTANT: keep the double quotes. The token contains '#' and dotenv would otherwise
# truncate it at the first '#', silently breaking auth.
EBAY_USER_REFRESH_TOKEN="your-refresh-token"
